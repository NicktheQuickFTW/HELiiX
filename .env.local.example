########################################
# Runtime - Node.js Server
########################################
NODE_ENV="development"
HOST="0.0.0.0"
PORT="4004"
PORT_OVERRIDE=
LOG_LEVEL=info
LOG_FILE=logs/app.log
DEBUG=true

# Authentication & Security
JWT_SECRET=
API_JWT=
DISABLE_AUTH=true

# Client URLs
NEXT_PUBLIC_API_URL=http://localhost:4004
NEXT_PUBLIC_WS_URL="ws://localhost:4004/ws"
NEXT_PUBLIC_APP_VERSION=

########################################
# Supabase - Server
# Project: vfzgnvcwakjxtdsaedfq
########################################
SUPABASE_URL=https://vfzgnvcwakjxtdsaedfq.supabase.co
SUPABASE_DB_PASSWORD=
SUPABASE_DB_URL=
SUPABASE_DB_URL_RO=
NEON_DATABASE_URL=

# Connection strings
SUPABASE_CONNECTION_STRING=
DATABASE_URL=
DIRECT_URL=
CONNECTION_POOLER=
DB_SSL=1

# Database resilience controls
FT_DB_RESILIENCE_MODE=normal
FT_DB_QUEUE_ENABLED=1
FT_DB_QUEUE_MAX_AGE_MINUTES=120
FT_DB_REPLAY_BATCH_SIZE=25
FT_DB_FAILOVER_ALLOW_WRITES=0

# API Keys - NEW format (preferred) ✅
SUPABASE_SECRET=
SUPABASE_ACCESS_TOKEN=

# API Keys - Legacy JWT tokens (being phased out) ⚠️
SUPABASE_ANON_KEY=
