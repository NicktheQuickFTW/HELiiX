SLACK_WEBHOOK_FT_GYMNASTICS=
SLACK_WEBHOOK_FT_LACROSSE=
SLACK_WEBHOOK_FT_MENS_TENNIS=
SLACK_WEBHOOK_FT_SOCCER=
SLACK_WEBHOOK_FT_SOFTBALL=
SLACK_WEBHOOK_FT_VOLLEYBALL=
SLACK_WEBHOOK_FT_WOMENS_TENNIS=
SLACK_WEBHOOK_FT_WRESTLING=

########################################
# Redis (optional)
########################################
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_MEMORY_TTL=3600
ENABLE_REDIS_MEMORY=false

########################################
# CP-SAT (OR-Tools) Solver
########################################
ORTOOLS_SERVICE_URL=http://localhost:8088

########################################
# E2B Sandbox Execution
########################################
E2B_API_KEY=
E2B_TEMPLATE_SOLVER=flextime-solver-ortools:stable
E2B_TIMEOUT_MS=300000
E2B_MAX_CONCURRENCY=4
E2B_REMOTE_FAILURE_TRACKER_MAX_KEYS=2000
E2B_SOLVER_ROLLOUT_STAGE=canary
E2B_SOLVER_CANARY_SPORTS=WTN
E2B_SOLVER_FARM_SPORTS=BSB,SB,SOC,VB,MTN,WTN,WRE,FB,MBB,WBB,LAX,GYM,BVB
E2B_BROKER_ENABLED=false
E2B_SOLVER_SHADOW_MODE=false
E2B_SOLVER_PRIMARY=false
E2B_REPLAY_ENABLED=false

########################################
# FlexTime Feature Flags (Server)
########################################
FT_MINIMAL=
FTB_SCHEDULES_ENABLED=true
FTB_ENV_DEBUG=1
FTB_ENV_INCLUDE_WEB=1
FTB_ENV_EXTRA_FILES=

# AI/Agent features
FLEXTIME_AI_ENABLED=true
FT_BUILDER_AGENTS=true
FT_BUILDER_AGENTS_APPLY=true
FT_BUILDER_NOTIFICATIONS=true
FT_AGENT_PARALLEL_TOOL_CALLS=
AI_MAX_RUN_MS=

# Human-in-the-loop
FTB_HIL_AUTO_APPROVE_THRESHOLD=0.80
FTB_HIL_BYPASS=true
SQL_AGENT_HIL=

# Guardrails
FT_SOLVER_ALLOW_GUARDED_SPORTS=
FTB_ALLOW_GUARDRAILED_SPORTS=

# MCP & integrations
FTB_MCP_ENABLED=
FTB_MCP_TIMEOUT_MS=

# Knowledge graph & uploads
FTB_KG_ENABLED="true"
FT_UPLOAD_EXPORTS=true
FT_EXPORTS_BUCKET=ft-exports

# Genetic algorithm & jobs
FT_GA_ENABLED=true
FT_JOB_SCHEDULER_ENABLED=true

# Orchestration toggles
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=10000
RATE_LIMIT_WINDOW_MS=900000

########################################
# OpenTelemetry
########################################
OTEL_ENABLED=false
OTEL_SERVICE_NAME=flextime-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Scheduling params
MAX_SCHEDULE_ITERATIONS=1000
OPTIMIZATION_THRESHOLD=0.85
OPTIMIZATION_THRESHOLD_STEPS=10
SQL_AGENT_DEFAULT_LIMIT=5
SQL_AGENT_STATEMENT_TIMEOUT_MS=15000

########################################
# FlexTime Feature Flags (Frontend)
########################################
# All UI features are now always enabled
