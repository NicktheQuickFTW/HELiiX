################################################################################
# FlexTime Environment Configuration Template
# Last Updated: 2025-11-25
#
# Copy to .env.local for backend/agents and to web/.env.local for Next.js.
# Never commit real secrets. Keep Supabase MCP as the source of truth.
################################################################################

########################################
# 1) Runtime & HTTP
########################################
JWT_SECRET=<generate-with: openssl rand -base64 32>
NODE_ENV=development
HOST=0.0.0.0
PORT=4004
LOG_LEVEL=info
LOG_FILE=logs/app.log
DEBUG=true
DISABLE_AUTH=true
FT_MINIMAL=1

########################################
# 2) API endpoints
########################################
NEXT_PUBLIC_API_URL=http://localhost:4004
NEXT_PUBLIC_WS_URL=ws://localhost:4004/ws
NEXT_PUBLIC_USE_SUPABASE_MOCK=false
NEXT_PUBLIC_FT_BUILDER_SUPABASE_HEALTH_BANNER=true

########################################
# 3) Supabase (server)
# FlexTime project ref: vfzgnvcwakjxtdsaedfq
# NEW: use sb_secret_* / sb_publishable_* keys (API Keys tab)
# LEGACY: eyJhbGci... JWTs (Legacy API Keys tab)
########################################
SUPABASE_URL=<your-supabase-url>
SUPABASE_DB_PASSWORD=<your-db-password>
SUPABASE_CONNECTION_STRING=<your-connection-string>
CONNECTION_POOLER=<your-connection-pooler>
DATABASE_URL=<your-database-url>
DIRECT_URL=<your-direct-url>
NEON_DATABASE_URL=<your-neon-database-url>
DB_SSL=1
SUPABASE_SECRET=sb_secret_<your-secret-key>
SUPABASE_ANON_KEY=eyJhbGci<your-anon-jwt>
SUPABASE_SERVICE_KEY=eyJhbGci<your-service-jwt>
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci<your-service-role-jwt>
SUPABASE_ACCESS_TOKEN=<your-management-api-token>

# Resilience controls
FT_DB_RESILIENCE_MODE=normal
FT_DB_QUEUE_ENABLED=1
FT_DB_QUEUE_MAX_AGE_MINUTES=120
FT_DB_REPLAY_BATCH_SIZE=25
FT_DB_FAILOVER_ALLOW_WRITES=0

########################################
# 4) Supabase (frontend/public)
########################################
NEXT_PUBLIC_SUPABASE_URL=<your-supabase-url>
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-publishable-key>
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci<your-anon-jwt>

########################################
# 5) OAuth / client credentials
########################################
CLIENT_ID=<optional-client-id>
CLIENT_SECRET=<optional-client-secret>

########################################
# 6) LLMs, AI, and research providers
########################################
OPENAI_API_KEY=<your-openai-key>
OPENAI_MODEL=gpt-5.3-codex
ANTHROPIC_API_KEY=<your-anthropic-key>
ANTHROPIC_MODEL=claude-opus-4-6
ANTHROPIC_PTC_ENABLED=false
ANTHROPIC_THINKING_ENABLED=false
LLM_MULTI_PROVIDER_ENABLED=true

# Legacy aliases kept for one release window:
# FT_ANTHROPIC_MODEL, FT_ANTHROPIC_PTC_ENABLED, FT_ANTHROPIC_THINKING_ENABLED, FT_ALLOW_NON_OPENAI

# Cadence AI Skills (Agent Skills API)
# Obtain skill IDs after uploading via Skills API

########################################
# 6a) Remote MCP OAuth Tokens
# Obtain tokens via: npx @modelcontextprotocol/inspector
########################################
# Gamma - Presentations, documents, webpages (https://mcp.gamma.app/mcp)

# Linear - Issue tracking, projects (https://mcp.linear.app/mcp)

# Sentry - Error debugging (https://mcp.sentry.dev/mcp)

# Figma - Design system (https://mcp.figma.com/mcp)

# Notion - Documentation (https://mcp.notion.com/mcp)

# Canva - Marketing materials (https://mcp.canva.com/mcp)

# Scholar Gateway - Research citations (https://connector.scholargateway.ai/mcp)

PERPLEXITY_API_KEY=<your-perplexity-key>
PERPLEXITY_TIMEOUT_MS=600000
GEMINI_API_KEY=<your-gemini-key>

# Google Interactions API (Stateful AI sessions, Deep Research)
XAI_API_KEY=<your-xai-key>
JINA_API_KEY=<your-jina-key>
########################################
# LangChain / LangSmith Configuration
########################################
LANGSMITH_API_KEY=<your-langsmith-key>

########################################
# 7) Vector DB & caching
########################################
PINECONE_API_KEY=<your-pinecone-key>
VECTOR_DB_API_KEY=<your-vector-db-key>

########################################
# 7a) Cadence Memory Providers
########################################

ENABLE_REDIS_MEMORY=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_MEMORY_TTL=3600

########################################
# 8) ClickHouse (telemetry/analytics)
########################################

########################################
# 9) Slack & notifications
########################################
FT_BUILDER_NOTIFICATIONS=true
SLACK_APP_TOKEN=<xapp-token>
SLACK_BOT_TOKEN=<xoxb-token>
SLACK_SIGNING_SECRET=<signing-secret>
SLACK_API_KEY=<api-key>
FT_SLACK_SOCKET_MODE=true
SLACK_WEBHOOK_FT_BASEBALL=<webhook-url>
SLACK_WEBHOOK_FT_SOCCER=<webhook-url>
SLACK_WEBHOOK_FT_SOFTBALL=<webhook-url>
SLACK_WEBHOOK_FT_GYMNASTICS=<webhook-url>
SLACK_WEBHOOK_FT_WRESTLING=<webhook-url>
SLACK_WEBHOOK_FT_WOMENS_TENNIS=<webhook-url>
SLACK_WEBHOOK_FT_MENS_TENNIS=<webhook-url>
SLACK_WEBHOOK_FT_LACROSSE=<webhook-url>
SLACK_WEBHOOK_FT_VOLLEYBALL=<webhook-url>

########################################
# 9a) PagerDuty Alerting (Level 4 Agent Readiness)
# See docs/operations/runbooks/alerting-rules.md for severity definitions
########################################

########################################
# 9b) Factory.ai Readiness Monitoring
# See https://docs.factory.ai/reference/readiness-reports-api
########################################
FACTORY_API_KEY=<your-factory-api-key>

########################################
# 10) Integrations & tooling
########################################
LINEAR_API_KEY=<your-linear-key>
GITHUB_TOKEN=<your-github-token>
NOTION_API_KEY=<your-notion-key>
GOOGLE_MAPS_API_KEY=<your-google-maps-key>
DOCKER_PAT=<your-docker-pat>
PERCY_TOKEN=<your-percy-token>
E2B_API_KEY=<your-e2b-key>
E2B_TEMPLATE_SOLVER=flextime-solver-ortools:stable
E2B_TIMEOUT_MS=300000
E2B_MAX_CONCURRENCY=4
E2B_REMOTE_FAILURE_TRACKER_MAX_KEYS=2000
E2B_SOLVER_ROLLOUT_STAGE=canary
E2B_SOLVER_CANARY_SPORTS=WTN
E2B_SOLVER_FARM_SPORTS=BSB,SB,SOC,VB,MTN,WTN,WRE,FB,MBB,WBB,LAX,GYM,BVB

########################################
# 11) Builder & agent feature flags
########################################
FT_BUILDER_AGENTS=true
FT_BUILDER_AGENTS_APPLY=true
FT_JOB_SCHEDULER_ENABLED=true
FT_GA_ENABLED=true
FLEXTIME_AI_ENABLED=true
FTB_MCP_ENABLED=true
FTB_ENV_INCLUDE_WEB=1
FTB_ENV_EXTRA_FILES=<comma-separated-env-files>
FTB_ENV_DEBUG=1
E2B_BROKER_ENABLED=false
E2B_SOLVER_SHADOW_MODE=false
E2B_SOLVER_PRIMARY=false
E2B_REPLAY_ENABLED=false

FTB_HIL_BYPASS=true
FTB_HIL_AUTO_APPROVE_THRESHOLD=0.80
FTB_SCHEDULES_ENABLED=true
FT_UPLOAD_EXPORTS=true
FT_EXPORTS_BUCKET=ft-exports

########################################
# 12) Scheduling engine defaults
########################################
MAX_SCHEDULE_ITERATIONS=1000
OPTIMIZATION_THRESHOLD=0.85
OPTIMIZATION_THRESHOLD_STEPS=10

########################################
# 13) Rate limiting
########################################
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=10000

########################################
# 14) SQL Agent defaults
########################################
SQL_AGENT_DEFAULT_LIMIT=5
SQL_AGENT_STATEMENT_TIMEOUT_MS=15000
SQL_AGENT_HIL=1

########################################
# 15) Solver services
########################################
ORTOOLS_SERVICE_URL=http://localhost:8088

# Provider Selection for A/B/C Testing
# PHASE1_SOLVER: cpsat (default) | gemini | anthropic | openai
# PHASE2_SOLVER: gemini (default if API key available) | anthropic | openai | glpk | mincostflow | auto

# Sport-specific Phase 2 solver overrides (optional)
# SOCCER_PHASE2_SOLVER=gemini
# BASEBALL_PHASE2_SOLVER=glpk

########################################
# 16) Statsig / experimentation
########################################
STATSIG_SERVER_API_KEY=<your-statsig-server-key>
NEXT_PUBLIC_STATSIG_CLIENT_KEY=<your-statsig-client-key>

########################################
# 17) Runtime parity keys (mirrored from .env)
########################################
AI_MAX_RUN_MS=
API_JWT=
FTB_ALLOW_GUARDRAILED_SPORTS=
FTB_KG_ENABLED=true
FTB_MCP_TIMEOUT_MS=
FT_AGENT_PARALLEL_TOOL_CALLS=
FT_SOLVER_ALLOW_GUARDED_SPORTS=
GAMMA_API_KEY=<your-gamma-key>
LANGSMITH_TRACING_ENABLED=true
LINEAR_TOKEN=<your-linear-token>
NEO4J_DATABASE=
NEO4J_PASSWORD=
NEO4J_URI=
NEO4J_USERNAME=
NEXT_PUBLIC_FT_HEALTH_POLL_MS=
NEXT_PUBLIC_SENTRY_DSN=
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=flextime-backend
PORT_OVERRIDE=
POSTGRES_DATABASE=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_PRISMA_URL=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
SENTRY_AUTH_TOKEN=<your-sentry-auth-token>
SENTRY_ORG=<your-sentry-org>
SENTRY_OTLP_TRACES_URL=<your-sentry-otlp-url>
SENTRY_PROJECT=<your-sentry-project>
SENTRY_PUBLIC_KEY=<your-sentry-public-key>
SENTRY_VERCEL_LOG_DRAIN_URL=<your-sentry-vercel-log-drain-url>
SUPABASE_DB_URL=
SUPABASE_DB_URL_RO=
SUPABASE_JWT_SECRET=
VERCEL_OIDC_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
VERCEL_TOKEN=

################################################################################
# Notes
# - Keep secrets out of version control.
# - For production, use platform secret managers (Vercel/AWS/etc.).
# - Supabase MCP first for any data operations.
################################################################################
